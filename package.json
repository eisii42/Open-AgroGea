{
  "name": "agrogea",
  "private": true,
  "version": "0.1.0",
  "description": "AgroGea — suite agronomica e di gestione del territorio local-first. Opera derivata di GeoLibre (MIT).",
  "license": "AGPL-3.0-or-later",
  "author": "Andrea Carnasciali",
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "trustedDependencies": [
    "core-js",
    "protobufjs"
  ],
  "scripts": {
    "dev": "npm run dev -w agro-field-suite",
    "dev:standalone": "npm run dev:standalone -w agro-field-suite",
    "build": "npm run build -w agro-field-suite",
    "build:standalone": "npm run build:standalone -w agro-field-suite",
    "typecheck": "tsc -p apps/agro-field-suite/tsconfig.json --noEmit",
    "lint": "eslint apps packages plugins tests",
    "test": "node --import tsx --test tests/agro-*.test.ts",
    "licenses:agro": "node scripts/gen-third-party-licenses.mjs",
    "tauri": "npm run tauri -w agro-field-suite",
    "tauri:dev": "npm run tauri dev -w agro-field-suite",
    "tauri:build": "npm run tauri build -w agro-field-suite",
    "check:rust": "cargo check --manifest-path apps/agro-field-suite/src-tauri/Cargo.toml"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "@types/node": "^22.19.21",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tsx": "^4.22.4",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
